__pycache__/
*.pyc

# Per-machine Python environment created by run.bat
.venv/

# Job folders are work products (customer data + generated PDFs) — never
# version-controlled. Only the _template scaffold ships, so new_job.py and
# the web UI can create jobs on a fresh clone.
/jobs/*
!/jobs/_template/

# PyInstaller build outputs (the .spec is tracked; the artifacts are not)
/build_pyi/
/dist/
build_pyi_log.txt
